State('schedule');\n  const [isLoading, setIsLoading] = useState(false);\n\n  useEffect(() => {\n    if (id && id !== 'new') {\n      const fetchService = async () => {\n        try {\n          const res = await organiserService.getServices();\n          const service = (res.data || []).find(s => String(s.id) === String(id));\n          if (service) {\n            dispatch({ type: 'SET_DATA', value: {\n              title: service.name,\n              duration: service.duration_min ? String(service.duration_min).padStart(2,'0') + ':00' : '00:30',\n              location: service.location || '',\n              description: service.description || '',\n              manualConfirmation: service.manual_confirmation || false,\n              paidBooking: service.advance_payment || false,\n            }});\n          }\n        } catch (err) {\n          console.error(err);","node_kind":"component"},{"id":"appointmenteditor_appointmenteditor_fetchservice","label":"fetchService()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L61-L78","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L61"}],"snippet":"fetchService = async () => {\n        try {\n          const res = await organiserService.getServices();\n          const service = (res.data || []).find(s => String(s.id) === String(id));\n          if (service) {\n            dispatch({ type: 'SET_DATA', value: {\n              title: service.name,\n              duration: service.duration_min ? String(service.duration_min).padStart(2,'0') + ':00' : '00:30',\n              location: service.location || '',\n              description: service.description || '',\n              manualConfirmation: service.manual_confirmation || false,\n              paidBooking: service.advance_payment || false,\n            }});\n          }\n        } catch (err) {\n          console.error(err);\n        }\n      }"},{"id":"appointmenteditor_appointmenteditor_handlesave","label":"handleSave()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L83-L106","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L83"}],"snippet":"handleSave = async () => {\n    setIsLoading(true);\n    try {\n      const payload = {\n        name: state.formData.title,\n        duration_min: parseInt(state.formData.duration) || 30,\n        location: state.formData.location,\n        description: state.formData.description,\n        manual_confirmation: state.formData.manualConfirmation,\n        advance_payment: state.formData.paidBooking,\n        capacity: 1,\n      };\n      if (state.isNew) {\n        await organiserService.createService(payload);\n      } else {\n        await organiserService.updateService(id, payload);\n      }\n      navigate('/organiser');\n    } catch (err) {\n      alert(err.response?.data?.error?.message || 'Failed to save.');\n    } finally {\n      setIsLoading(false);\n    }\n  }"},{"id":"appointmenteditor_appointmenteditor_updatefield","label":"updateField()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L108-L110","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L108"}],"snippet":"updateField = (field, value) => {\n    dispatch({ type: 'UPDATE_FIELD', field, value });\n  }"},{"id":"c_1_programming_0_projects_zi