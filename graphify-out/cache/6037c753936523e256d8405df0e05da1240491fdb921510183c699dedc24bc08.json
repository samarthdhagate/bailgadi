{"__graphifyTsExtractorVersion":61,"nodes":[{"id":"authcontext","label":"AuthContext.jsx","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/context/AuthContext.jsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/context/AuthContext.jsx","source_location":"L1"}]},{"id":"authcontext_authprovider","label":"AuthProvider()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/context/AuthContext.jsx","source_location":"L6-L47","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/context/AuthContext.jsx","source_location":"L6"}],"snippet":"AuthProvider = ({ children }) => {\n  const [user, setUser] = useState(null);\n  const [token, setToken] = useState(localStorage.getItem('token'));\n  const [role, setRole] = useState(localStorage.getItem('role'));\n  const navigate = useNavigate();\n\n  useEffect(() => {\n    if (token) {\n      // In a real app, we might validate the token here\n      setUser({ token, role });\n    }\n  }, [token, role]);\n\n  const login = (userData) => {\n    const { token, role, user } = userData;\n    localStorage.setItem('token', token);\n    localStorage.setItem('role', role);\n    setToken(token);\n    setRole(role);\n    setUser(user);\n\n    // Redirect based on role\n    if (role === 'customer') navigate('/dashboard');\n    else if (role === 'organiser') navigate('/organiser');\n    else if (role === 'admin') navigate('/admin');","node_kind":"component"},{"id":"authcontext_authprovider_login","label":"login()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/context/AuthContext.jsx","source_location":"L19-L31","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/context/AuthContext.jsx","source_location":"L19"}],"snippet":"login = (userData) => {\n    const { token, role, user } = userData;\n    localStorage.setItem('token', token);\n    localStorage.setItem('role', role);\n    setToken(token);\n    setRole(role);\n    setUser(user);\n\n    // Redirect based on role\n    if (role === 'customer') navigate('/dashboard');\n    else if (role === 'organiser') navigate('/organiser');\n    else if (role === 'admin') navigate('/admin');\n  }"},{"id":"authcontext_authprovider_logout","label":"logout()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/context/AuthContext.jsx","source_location":"L33-L40","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/context/AuthContext.jsx","source_location":"L33"}],"snippet":"logout = () => {\n    localStorage.removeItem('token');\n    localStorage.removeItem('role');\n    setToken(null);\n    setRole(null);\n    setUser(null);\n    navigate('/login');\n  }"},{"id":"authcontext_useauth","label":"useAuth()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/context/AuthContext.jsx","source_location":"L49-L55","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/context/AuthContext.jsx","source_location":"L49"}],"snippet":"useAuth = () => {\n  const context = useContext(AuthContext);\n  if (!context) {\n    throw new Error('useAuth must be used within an AuthProvider');\n  }\n  return context;\n}"}],"edges":[{"source":"authcontext","target":"react","relation":"imports_from","confidence":"EXTRACTED","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/context/AuthContext.jsx","source_location":"L1","layer":"base","provenan