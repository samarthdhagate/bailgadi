escheduling, skip details and payment\n      submitBooking();\n      return;\n    }\n\n    if (step === 2) {\n      if (service?.price > 0) {\n        setStep(3); // Payment\n      } else {\n        submitBooking();\n      }\n    } else {\n      setStep(prev => prev + 1);\n    }\n  }"},{"id":"bookingwizard_bookingwizard_handleback","label":"handleBack()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L92-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L92"}],"snippet":"handleBack = () => {\n    setStep(prev => prev - 1);\n  }"},{"id":"bookingwizard_bookingwizard_submitbooking","label":"submitBooking()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L96-L123","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L96"}],"snippet":"submitBooking = async () => {\n    setIsLoading(true);\n    setError('');\n    try {\n      // Lock the slot first\n      await bookingService.lockSlot(serviceId, bookingData.time);\n      // Create the booking\n      const res = await bookingService.createBooking({\n        serviceId,\n        startTime: bookingData.time,\n        notes: `${bookingData.userDetails.name} — ${bookingData.userDetails.phone}`,\n      });\n      navigate('/confirmation', {\n        state: {\n          booking: {\n            ...res.data,\n            date: new Date(res.data.start_time).toLocaleDateString(),\n            time: new Date(res.data.start_time).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),\n            userDetails: bookingData.userDetails,\n          }\n        }\n      });\n    } catch (err) {\n      setError(err.response?.data?.error?.message || 'Failed to confirm booking');\n    } finally {"},{"id":"bookingwizard_bookingwizard_renderunifiedselection","label":"renderUnifiedSelection()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L125-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L125"}],"snippet":"renderUnifiedSelection = () => {\n    return (\n      <div className=\"flex flex-col gap-10\">\n        {resources.length > 0 && (\n          <div>\n            <h3 className=\"text-sm font-bold text-gray-400 uppercase tracking-wider mb-4\">With</h3>\n            <div className=\"flex flex-wrap gap-4\">\n              {resources.map(r => (\n                <button\n                  key={r.id}\n                  onClick={() => setBookingData(prev => ({ ...prev, resourceId: r.id }))}\n                  className={`flex items-center gap-3 px-4 py-2 rounded-xl border-2 transition-all ${\n                    bookingData.resourceId === r.id\n                      ? 'border-primary bg-primary/5 text-primary'\n                      : 'border-gray-100 bg-white text-gray-600 hover:border-gray-200'\n                  }`}\n                >\n                  <div className={`w-8 h-8 rounded-lg flex items-center justify-center font-bold text-xs ${\n                    bookingData.resourceId === r.id ? 'bg-primary text-white' : 'bg-gray-100 text-gray-400'\n                  }`}>\n                    U{r.id}\n                  </div>\n                  <span className=\"font-semibold\">{r.name}</span>\n                </button>\n              ))}"},{"id":"bookingwizard_bookingwizard_renderstep","label":"renderStep()","file_type":"code","sou