{"__graphifyTsExtractorVersion":61,"nodes":[{"id":"bookingwizard","label":"BookingWizard.jsx","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L1"}]},{"id":"bookingwizard_bookingwizard","label":"BookingWizard()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L34-L524","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L34"}],"snippet":"BookingWizard = () => {\n  const { serviceId } = useParams();\n  const navigate = useNavigate();\n  const location = useLocation();\n  const existingBooking = location.state?.reschedulingBooking;\n  \n  const [step, setStep] = useState(1);\n  const [isLoading, setIsLoading] = useState(false);\n  const [error, setError] = useState('');\n  const [isRescheduling, setIsRescheduling] = useState(!!existingBooking);\n  \n  const [bookingData, setBookingData] = useState({\n    serviceId: serviceId,\n    resourceId: existingBooking?.resourceId || 'default',\n    date: existingBooking?.date || new Date().toISOString().split('T')[0],\n    time: existingBooking?.time || null,\n    capacity: existingBooking?.capacity || 1,\n    userDetails: existingBooking?.userDetails || {\n      name: '',\n      email: '',\n      phone: ''\n    }\n  });\n\n  const [currentMonth, setCurrentMonth] = useState(new Date());","node_kind":"component"},{"id":"bookingwizard_bookingwizard_init","label":"init()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L64-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L64"}],"snippet":"init = async () => {\n      setIsLoading(true);\n      try {\n        const res = await bookingService.getServices();\n        const currentService = (res.data || []).find(s => String(s.id) === String(serviceId));\n        setService(currentService);\n\n        // Fetch resources (mocked for now in service, but let's set some defaults)\n        const resData = await bookingService.getResources(serviceId);\n        setResources(resData.data || []);\n        if (resData.data?.length > 0 && !bookingData.resourceId) {\n          setBookingData(prev => ({ ...prev, resourceId: resData.data[0].id }));\n        }\n      } catch (err) {\n        setError('Failed to load service details');\n      } finally {\n        setIsLoading(false);\n      }\n    }"},{"id":"bookingwizard_bookingwizard_fetchslots","label":"fetchSlots()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L88-L99","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L88"}],"snippet":"fetchSlots = async () => {\n        setIsLoading(true);\n        setError('');\n        try {\n          const res = await bookingService.getSlots(serviceId, bookingData.date);\n          setSlots(res.data || []);\n        } catch (err) {\n          setError('Failed to load available slots');\n        } finally {\n          setIsLoading(false);\n        }\n      }"},{"id":"bookingwizard_bookingwizard_handlenext","label":"handleNext()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L104-L119","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L104"}],"snippet":"handleNext = () => {\n    if (isRescheduling && step === 1) {\n      submitBooking();\n      return;\n    }\n\n    if (step === 2) {\n      if (service?.price > 0) {\n        setStep(3);\n      } else {\n        submitBooking();\n      }\n    } else {\n      setStep(prev => prev + 1);\n    }\n  }"},{"id":"bookingwizard_bookingwizard_submitbooking","label":"submitBooking()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L121-L148","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L121"}],"snippet":"submitBooking = async () => {\n    setIsLoading(true);\n    setError('');\n    try {\n      await bookingService.lockSlot(serviceId, bookingData.time);\n      const res = await bookingService.createBooking({\n        ...bookingData,\n        serviceId,\n        startTime: bookingData.time,\n      });\n      \n      navigate('/confirmation', {\n        state: {\n          booking: {\n            ...res.data,\n            serviceName: service?.name || service?.title,\n            date: bookingData.date,\n            time: bookingData.time,\n            userDetails: bookingData.userDetails,\n          }\n        }\n      });\n    } catch (err) {\n      setError(err.response?.data?.error?.message || 'Failed to confirm booking');\n    } finally {"},{"id":"bookingwizard_bookingwizard_rendercalendar","label":"renderCalendar()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L151-L226","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L151"}],"snippet":"renderCalendar = () => {\n    const monthStart = startOfMonth(currentMonth);\n    const monthEnd = endOfMonth(monthStart);\n    const startDate = startOfWeek(monthStart);\n    const endDate = endOfWeek(monthEnd);\n\n    const dateFormat = \"d\";\n    const rows = [];\n    let days = [];\n    let day = startDate;\n    let formattedDate = \"\";\n\n    const calendarDays = eachDayOfInterval({\n      start: startDate,\n      end: endDate\n    });\n\n    const daysOfWeek = ['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa'];\n\n    return (\n      <div className=\"w-full\">\n        {/* Calendar Header */}\n        <div className=\"flex items-center justify-between mb-8\">\n          <button \n            onClick={() => setCurrentMonth(subMonths(currentMonth, 1))}"},{"id":"bookingwizard_bookingwizard_renderunifiedselection","label":"renderUnifiedSelection()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L228-L336","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L228"}],"snippet":"renderUnifiedSelection = () => {\n    return (\n      <div className=\"flex flex-col gap-10\">\n        {resources.length > 0 && (\n          <div>\n            <h3 className=\"text-sm font-bold text-gray-400 uppercase tracking-wider mb-4\">With</h3>\n            <div className=\"flex flex-wrap gap-4\">\n              {resources.map(r => (\n                <button\n                  key={r.id}\n                  onClick={() => setBookingData(prev => ({ ...prev, resourceId: r.id }))}\n                  className={`flex items-center gap-3 px-4 py-2 rounded-xl border-2 transition-all ${\n                    bookingData.resourceId === r.id\n                      ? 'border-primary bg-primary/5 text-primary'\n                    : 'border-gray-100 bg-white text-gray-600 hover:border-gray-200'\n                }`}\n              >\n                <div className={`w-10 h-10 rounded-xl flex items-center justify-center font-bold text-sm ${\n                  bookingData.resourceId === r.id ? 'bg-primary text-white' : 'bg-gray-100 text-gray-400'\n                }`}>\n                  {r.name.split(' ').map(n => n[0]).join('')}\n                </div>\n                <span className=\"font-bold\">{r.name}</span>\n              </button>\n            ))}"},{"id":"bookingwizard_bookingwizard_renderstep","label":"renderStep()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L338-L490","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/BookingWizard.jsx","source_location":"L338"}],"snippet":"renderStep = () => {\n    if (step === 1) return renderUnifiedSelection();\n    \n    switch (step) {\n      case 2:\n        return (\n          <div className=\"flex flex-col gap-8 max-w-4xl mx-auto\">\n            <div className=\"border-b border-gray-100 pb-6\">\n              <h2 className=\"text-3xl font-bold text-gray-800 tracking-tighter\">Details</h2>\n              <p className=\"text-gray-500 mt-2 font-medium\">Please provide your contact information to confirm your booking.</p>\n            </div>\n\n            <div className=\"space-y-8 py-4\">\n              <div className=\"grid grid-cols-1 md:grid-cols-3 items-center gap-4\">\n                <label className=\"font-bold text-gray-700\">Full Name</label>\n                <div class