{"__graphifyTsExtractorVersion":61,"nodes":[{"id":"appointmenteditor","label":"AppointmentEditor.jsx","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L1"}]},{"id":"appointmenteditor_reducer","label":"reducer()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L42-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L42"}],"snippet":"function reducer(state, action) {\n  switch (action.type) {\n    case 'SET_LOADING':\n      return { ...state, isLoading: action.value };\n    case 'SET_DATA':\n      return { ...state, formData: { ...state.formData, ...action.value }, isNew: false };\n    case 'UPDATE_FIELD':\n      return { ...state, formData: { ...state.formData, [action.field]: action.value } };\n    default:\n      return state;\n  }\n}"},{"id":"appointmenteditor_appointmenteditor","label":"AppointmentEditor()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L55-L676","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L55"}],"snippet":"AppointmentEditor = () => {\n  const { id } = useParams();\n  const navigate = useNavigate();\n  const fileInputRef = useRef(null);\n  const [state, dispatch] = useReducer(reducer, initialState);\n  const [activeTab, setActiveTab] = useState('schedule');\n  const [isPreviewOpen, setIsPreviewOpen] = useState(false);\n  const [isAddingUser, setIsAddingUser] = useState(false);\n  const [newUserName, setNewUserName] = useState('');\n\n  // Local state for users/staff - start empty\n  const [staff, setStaff] = useState([]);\n\n  useEffect(() => {\n    if (id && id !== 'new') {\n      const fetchService = async () => {\n        dispatch({ type: 'SET_LOADING', value: true });\n        try {\n          const res = await organiserService.getServices();\n          const service = (res.data || []).find(s => String(s.id) === String(id));\n          if (service) {\n            dispatch({ type: 'SET_DATA', value: {\n              title: service.name,\n              duration: service.duration_min ? String(Math.floor(service.duration_min / 60)).padStart(2,'0') + ':' + String(service.duration_min % 60).padStart(2,'0') : '00:30',\n              location: service.location || '',","node_kind":"component"},{"id":"appointmenteditor_appointmenteditor_fetchservice","label":"fetchService()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L70-L92","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L70"}],"snippet":"fetchService = async () => {\n        dispatch({ type: 'SET_LOADING', value: true });\n        try {\n          const res = await organiserService.getServices();\n          const service = (res.data || []).find(s => String(s.id) === String(id));\n          if (service) {\n            dispatch({ type: 'SET_DATA', value: {\n              title: service.name,\n              duration: service.duration_min ? String(Math.floor(service.duration_min / 60)).padStart(2,'0') + ':' + String(service.duration_min % 60).padStart(2,'0') : '00:30',\n              location: service.location || '',\n              description: service.description || '',\n              manualConfirmation: service.manual_confirmation || false,\n              paidBooking: service.advance_payment || false,\n              image: service.image || '',\n              price: service.price || 0\n            }});\n          }\n        } catch (err) {\n          console.error(err);\n        } finally {\n          dispatch({ type: 'SET_LOADING', value: false });\n        }\n      }"},{"id":"appointmenteditor_appointmenteditor_handlesave","label":"handleSave()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L97-L128","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L97"}],"snippet":"handleSave = async () => {\n    dispatch({ type: 'SET_LOADING', value: true });\n    try {\n      const durationParts = state.formData.duration.split(':');\n      const duration_min = (parseInt(durationParts[0]) * 60) + parseInt(durationParts[1]);\n      \n      const payload = {\n        name: state.formData.title,\n        duration_min: duration_min || 30,\n        location: state.formData.location,\n        description: state.formData.description,\n        manual_confirmation: state.formData.manualConfirmation,\n        advance_payment: state.formData.paidBooking,\n        capacity: 1,\n        price: state.formData.price,\n        image: state.formData.image,\n        questions: state.formData.questions,\n        assigned_users: state.formData.selectedUsers\n      };\n\n      if (state.isNew) {\n        await organiserService.createService(payload);\n      } else {\n        await organiserService.updateService(id, payload);\n      }"},{"id":"appointmenteditor_appointmenteditor_updatefield","label":"updateField()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L130-L132","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L130"}],"snippet":"updateField = (field, value) => {\n    dispatch({ type: 'UPDATE_FIELD', field, value });\n  }"},{"id":"appointmenteditor_appointmenteditor_handleimageupload","label":"handleImageUpload()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L134-L143","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L134"}],"snippet":"handleImageUpload = (e) => {\n    const file = e.target.files[0];\n    if (file) {\n      const reader = new FileReader();\n      reader.onloadend = () => {\n        updateField('image', reader.result);\n      };\n      reader.readAsDataURL(file);\n    }\n  }"},{"id":"appointmenteditor_appointmenteditor_addavailabilityline","label":"addAvailabilityLine()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L145-L153","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L145"}],"snippet":"addAvailabilityLine = () => {\n    const newLine = {\n      id: Date.now(),\n      day: 'Monday',\n      startTime: '09:00',\n      endTime: '12:00'\n    };\n    updateField('availability', [...state.formData.availability, newLine]);\n  }"},{"id":"appointmenteditor_appointmenteditor_removeavailabilityline","label":"removeAvailabilityLine()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L155-L157","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L155"}],"snippet":"removeAvailabilityLine = (id) => {\n    updateField('availability', state.formData.availability.filter(a => a.id !== id));\n  }"},{"id":"appointmenteditor_appointmenteditor_updateavailabilityline","label":"updateAvailabilityLine()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L159-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L159"}],"snippet":"updateAvailabilityLine = (id, field, value) => {\n    const updated = state.formData.availability.map(a => \n      a.id === id ? { ...a, [field]: value } : a\n    );\n    updateField('availability', updated);\n  }"},{"id":"appointmenteditor_appointmenteditor_toggleuserselection","label":"toggleUserSelection()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L166-L173","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L166"}],"snippet":"toggleUserSelection = (userId) => {\n    const selected = state.formData.selectedUsers;\n    if (selected.includes(userId)) {\n      updateField('selectedUsers', selected.filter(id => id !== userId));\n    } else {\n      updateField('selectedUsers', [...selected, userId]);\n    }\n  }"},{"id":"appointmenteditor_appointmenteditor_addnewuser","label":"addNewUser()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L175-L187","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L175"}],"snippet":"addNewUser = () => {\n    if (!newUserName) return;\n    const newUser = {\n      id: Date.now(),\n      name: newUserName,\n      initial: newUserName.split(' ').map(n => n[0]).join('').toUpperCase().substring(0, 2)\n    };\n    setStaff([...staff, newUser]);\n    // Auto select new user\n    updateField('selectedUsers', [...state.formData.selectedUsers, newUser.id]);\n    setNewUserName('');\n    setIsAddingUser(false);\n  }"},{"id":"c_1_programming_0_projects_zilla_zilla_frontend_src_nextjs_route_organiser_appointmenteditor","label":"/organiser/AppointmentEditor","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/organiser/AppointmentEditor.jsx","source_location":"L1"}],"node_kind":"route","framework":"nextjs","framework_role":"next_route","route_path":"/organiser/AppointmentEditor"},{"id":"c_1_programming_0_projects_zilla_zilla_frontend_src_nextjs_page_organiser_appointmenteditor","label":"page /organiser/AppointmentEditor","file_type":"code","source_file":"C:\\1_PROGRAMMING\\0_Projects\\Zilla\\Zilla\\frontend\\src\\pages\\organiser\\AppointmentEditor.jsx","source_location":"L1","layer":"base","provenance":[{"capability_i