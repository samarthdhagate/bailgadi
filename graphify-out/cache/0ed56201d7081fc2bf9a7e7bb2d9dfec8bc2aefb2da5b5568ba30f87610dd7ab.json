ase 'rescheduled':\n        return 'bg-blue-100 text-blue-700 border-blue-200';\n      default:\n        return 'bg-gray-100 text-gray-700 border-gray-200';\n    }\n  }"},{"id":"mybookings_mybookings_getstatusicon","label":"getStatusIcon()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/MyBookings.jsx","source_location":"L61-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/MyBookings.jsx","source_location":"L61"}],"snippet":"getStatusIcon = (status) => {\n    switch (status?.toLowerCase()) {\n      case 'booked':\n      case 'confirmed':\n        return <CheckCircle className=\"w-4 h-4\" />;\n      case 'pending':\n      case 'locked':\n        return <Clock3 className=\"w-4 h-4\" />;\n      case 'cancelled':\n        return <XCircle className=\"w-4 h-4\" />;\n      default:\n        return null;\n    }\n  }"},{"id":"mybookings_mybookings_formatdate","label":"formatDate()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/MyBookings.jsx","source_location":"L76-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/MyBookings.jsx","source_location":"L76"}],"snippet":"formatDate = (isoString) => {\n    if (!isoString) return '';\n    try {\n      const d = new Date(isoString);\n      if (isNaN(d.getTime())) return isoString; // Return as is if not ISO\n      return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });\n    } catch (e) { return isoString; }\n  }"},{"id":"mybookings_mybookings_formattime","label":"formatTime()","file_type":"code","source_file":"C:/1_PROGRAMMING/0_Projects/Zilla/Zilla/frontend/src/pages/customer/MyBookings.jsx","source_location":"L85-L92","layer":"ba