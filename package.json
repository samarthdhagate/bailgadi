{
  "name": "zilla-monorepo",
  "private": true,
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=zilla-backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "install:all": "npm install && npm install --workspace=frontend && npm install --workspace=zilla-backend"
  },
  "workspaces": [
    "frontend",
    "zilla-backend",
    "services"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
