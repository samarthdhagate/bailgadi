PORT=5000
NODE_ENV=development

# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/zilla?sslmode=require

# Upstash Redis
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=your_token

# JWT
JWT_SECRET=your_32_char_secret_minimum_length
JWT_REFRESH_SECRET=your_other_32_char_secret_minimum

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_DEMO_MODE=false

# Nodemailer SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@zilla.app

# Frontend
FRONTEND_URL=http://localhost:5173

# Google Sign-In (OAuth 2.0) — Get credentials in Google Cloud Console.
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# AI
GEMINI_API_KEY=your_gemini_api_key
